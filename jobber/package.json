{
  "name": "queue-lab",
  "version": "0.1.0",
  "description": "Small educational TypeScript queue library for studying async concurrency.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.*",
    "dist/queue.*",
    "dist/worker.*",
    "dist/types.*",
    "dist/errors.*",
    "dist/job.*",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "example": "npm run build && tsx examples/concurrency-demo.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
